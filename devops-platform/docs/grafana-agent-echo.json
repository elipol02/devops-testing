{
  "annotations": {"list": []},
  "editable": true,
  "schemaVersion": 39,
  "title": "agent-echo (per tenant)",
  "tags": ["devops-platform", "agent-echo"],
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "tenant",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(agent_echo_requests_total, kubernetes_namespace)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Requests / sec by endpoint",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(agent_echo_requests_total{kubernetes_namespace=~\"$tenant\"}[5m]))",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "5xx rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (status) (rate(agent_echo_requests_total{kubernetes_namespace=~\"$tenant\",status=~\"5..\"}[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "OpenRouter p95 latency",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, model) (rate(agent_echo_openrouter_latency_seconds_bucket{kubernetes_namespace=~\"$tenant\"}[5m])))",
          "legendFormat": "p95 {{model}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Tokens / min",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (kind) (rate(agent_echo_openrouter_tokens_total{kubernetes_namespace=~\"$tenant\"}[5m])) * 60",
          "legendFormat": "{{kind}}"
        }
      ]
    }
  ]
}
